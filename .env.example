# WeatherCore — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Database ──────────────────────────────
DB_HOST=localhost
DB_USER=weatheruser
DB_PASS=StrongPass!2025
DB_NAME=weathercore

# ── API Keys ──────────────────────────────
# Open-Meteo: NO KEY NEEDED (free, no registration)
# NASA POWER:  NO KEY NEEDED (free, no registration)

# OpenWeatherMap — register free at openweathermap.org
OWM_API_KEY=your_owm_api_key_here

# NOAA CDO — request free token at www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=your_noaa_token_here

# ── Flask ─────────────────────────────────
FLASK_ENV=development
PORT=5000

# ── Optional Redis ─────────────────────────
# REDIS_URL=redis://localhost:6379/0
